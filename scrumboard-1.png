void drawHeader() {
  disableTouch();
  display.fillRect(HEADER_X, HEADER_Y, HEADER_W, HEADER_H, NAVY);
  display.drawRoundRect(HEADER_X, HEADER_Y, HEADER_W, HEADER_H, 7, WHITE);
  display.setTextColor(WHITE, NAVY);
  display.setTextSize(3);
  display.setCursor(25, 28);
  display.print("Umweltstation");
  display.setTextSize(2);
  display.setCursor(345, 27);
  display.print("--:--:--");
  display.setTextSize(1);
  display.setCursor(350, 49);
  display.print("--.--.----");
}

void updateClock() {
  if (currentScreen != SCREEN_MAIN) return;
  DateTime now = rtc.now();
  disableTouch();
  display.fillRect(335, 23, 125, 34, NAVY);
  display.setTextColor(WHITE, NAVY);
  display.setTextSize(2);
  display.setCursor(345, 27);
  if (now.hour() < 10) display.print("0");
  display.print(now.hour());
  display.print(":");
  if (now.minute() < 10) display.print("0");
  display.print(now.minute());
  display.print(":");
  if (now.second() < 10) display.print("0");
  display.print(now.second());
  display.setTextSize(1);
  display.setCursor(350, 49);
  if (now.day() < 10) display.print("0");
  display.print(now.day());
  display.print(".");
  if (now.month() < 10) display.print("0");
  display.print(now.month());
  display.print(".");
  display.print(now.year());
}

void drawBox(int x, int y, int w, int h, uint16_t borderColor, const char* title, uint16_t titleColor) {
  disableTouch();
  display.drawRoundRect(x, y, w, h, 8, borderColor);
  display.fillRoundRect(x + 2, y + 2, w - 4, h - 4, 8, DARKGRAY);
  display.setTextColor(titleColor, DARKGRAY);
  display.setTextSize(2);
  display.setCursor(x + 10, y + 7);
  display.print(title);
}

void drawStatButton() {
  disableTouch();
  display.fillRoundRect(STAT_BTN_X, STAT_BTN_Y, STAT_BTN_W, STAT_BTN_H, 8, CYAN);
  display.drawRoundRect(STAT_BTN_X, STAT_BTN_Y, STAT_BTN_W, STAT_BTN_H, 8, WHITE);
  display.setTextColor(BLACK, CYAN);
  display.setTextSize(2);
  display.setCursor(STAT_BTN_X + 18, STAT_BTN_Y + 7);
  display.print("STAT");
}

void drawStaticUI() {
  disableTouch();
  display.fillScreen(BLACK);
  drawHeader();
  drawBox(BOX1_X, BOX1_Y, BOX_W, BOX_H, ORANGE, "Temperatur", ORANGE);
  drawBox(BOX2_X, BOX2_Y, BOX_W, BOX_H, CYAN, "Feuchte", CYAN);
  drawBox(BOX3_X, BOX3_Y, BOX_W, BOX_H, MAGENTA, "Druck", MAGENTA);
