void updateStatus(float gasKOhm) {
  disableTouch();
  const char* statusText;
  uint16_t statusColor;
  int percent = mapGasToPercent(gasKOhm);

  if (gasKOhm >= GAS_MEDIUM_THRESHOLD) {
    statusText = "Gut";
    statusColor = GREEN;
  } else if (gasKOhm >= GAS_BAD_THRESHOLD) {
    statusText = "Mittel";
    statusColor = YELLOW;
  } else {
    statusText = "Schlecht";
    statusColor = RED;
  }

  display.fillRect(170, 213, 130, 22, DARKGRAY);
  display.setTextColor(statusColor, DARKGRAY);
  display.setTextSize(2);
  display.setCursor(170, 216);
  display.print(statusText);
  display.fillRect(35, 242, 390, 12, BLACK);
  display.drawRect(35, 242, 390, 12, WHITE);
  int barWidth = map(percent, 0, 100, 0, 388);
  display.fillRect(36, 243, barWidth, 10, statusColor);
  display.fillRect(305, 213, 120, 22, DARKGRAY);
  display.setTextColor(WHITE, DARKGRAY);
  display.setTextSize(2);
  display.setCursor(305, 216);
  display.print(percent);
  display.print("%");
}

void updateFooterStatus() {
  if (currentScreen != SCREEN_MAIN) return;
  disableTouch();
  display.fillRect(220, FOOTER_Y, 135, FOOTER_H, NAVY);
  display.setTextSize(2);
  display.setCursor(225, 282);
  if (airBad && alarmMuted) {
    display.setTextColor(YELLOW, NAVY);
    display.print("Quittiert");
  } else if (airBad) {
    display.setTextColor(RED, NAVY);
    display.print("ALARM!");
  } else {
    display.setTextColor(WHITE, NAVY);
    display.print("Update OK");
  }
  drawStatButton();
}

void updateMainMeasurementDisplay() {
  if (currentScreen != SCREEN_MAIN) return;
  if (!hasSensorReading) return;
  updateValueBox(BOX1_X, BOX1_Y, currentTemp, "C");
  updateValueBox(BOX2_X, BOX2_Y, currentHum, "%");
  updateValueBox(BOX3_X, BOX3_Y, currentPressure, "hPa");
  updateValueBox(BOX4_X, BOX4_Y, currentGas, "KOhm");
  updateStatus(currentGas);
  updateFooterStatus();
}

// ======================================================
// STATS SCREEN
// ======================================================

void drawBackButton() {
  disableTouch();
  display.fillRoundRect(BACK_BTN_X, BACK_BTN_Y, BACK_BTN_W, BACK_BTN_H, 8, ORANGE);
  display.drawRoundRect(BACK_BTN_X, BACK_BTN_Y, BACK_BTN_W, BACK_BTN_H, 8, WHITE);
  display.setTextColor(BLACK, ORANGE);
  display.setTextSize(2);
  display.setCursor(BACK_BTN_X + 13, BACK_BTN_Y + 9);
  display.print("ZURUECK");
}

void drawGraphButton() {
  disableTouch();
  display.fillRoundRect(GRAPH_BTN_X, GRAPH_BTN_Y, GRAPH_BTN_W, GRAPH_BTN_H, 8, CYAN);
  display.drawRoundRect(GRAPH_BTN_X, GRAPH_BTN_Y, GRAPH_BTN_W, GRAPH_BTN_H, 8, WHITE);
  display.setTextColor(BLACK, CYAN);
  display.setTextSize(2);
  display.setCursor(GRAPH_BTN_X + 24, GRAPH_BTN_Y + 9);
  display.print("GRAPH");
}

void drawAlarmButton() {
  disableTouch();
  display.fillRoundRect(ALARM_BTN_X, ALARM_BTN_Y, ALARM_BTN_W, ALARM_BTN_H, 8, RED);
  display.drawRoundRect(ALARM_BTN_X, ALARM_BTN_Y, ALARM_BTN_W, ALARM_BTN_H, 8, WHITE);
  display.setTextColor(WHITE, RED);
  display.setTextSize(2);
  display.setCursor(ALARM_BTN_X + 18, ALARM_BTN_Y + 9);
  display.print("ALARME");
}

void printAverageBlock(int x, int y, const char* title, AverageStats stats) {
  display.setTextColor(CYAN, BLACK);
  display.setTextSize(2);
  display.setCursor(x, y);
  display.print(title);
  display.setTextColor(WHITE, BLACK);
  if (!stats.hasData) {
    display.setCursor(x, y + 28);
    display.print("Keine Daten");
    return;
  }
  display.setCursor(x, y + 28);
  display.print("T:"); display.print(stats.avgTemp, 1); display.print("C");
  display.setCursor(x, y + 52);
  display.print("F:"); display.print(stats.avgHum, 1); display.print("%");
  display.setCursor(x, y + 76);
  display.print("D:"); display.print(stats.avgPressure, 0); display.print("hPa");
  display.setCursor(x, y + 100);
  display.print("G:"); display.print(stats.avgGas, 1); display.print("K");
}

void drawStatsScreen() {
  disableTouch();
  display.fillScreen(BLACK);
  display.drawRect(10, 14, 460, 288, WHITE);
  display.fillRect(10, 14, 460, 42, NAVY);
  display.setTextColor(WHITE, NAVY);
  display.setTextSize(3);
  display.setCursor(25, 23);
  display.print("Statistik");
  AverageStats todayStats = calculateTodayAverage();
  AverageStats last24Stats = calculateLast24HoursAverage();
  printAverageBlock(30, 75, "Heute", todayStats);
  printAverageBlock(255, 75, "24h", last24Stats);
  display.setTextColor(YELLOW, BLACK);
  display.setTextSize(2);
  display.setCursor(30, 233);
  display.print("Log: ");
  if (last24Stats.hasData) {
    display.print(last24Stats.count);
    display.print(" Werte");
  } else {
    display.print("leer");
  }
  drawAlarmButton();
  drawGraphButton();
  drawBackButton();
}

// ======================================================
// ALARM LOG SCREEN
// ======================================================

void drawAlarmLogScreen() {
  disableTouch();
  display.fillScreen(BLACK);
  display.drawRect(10, 14, 460, 288, WHITE);
  display.fillRect(10, 14, 460, 42, RED);
  display.setTextColor(WHITE, RED);
  display.setTextSize(2);
  display.setCursor(25, 27);
  display.print("Alarm-Protokoll");

  String lines[5];
  int lineCount = 0;
  File file = LittleFS.open(ALARM_FILE, FILE_READ);

  if (file) {
    while (file.available()) {
      String line = file.readStringUntil('\n');
      line.trim();
      if (line.length() == 0 || line.startsWith("epoch")) continue;
      if (lineCount < 5) {
        lines[lineCount] = line;
        lineCount++;
      } else {
        for (int i = 0; i < 4; i++) lines[i] = lines[i + 1];
        lines[4] = line;
      }
    }
    file.close();
  }

  if (lineCount == 0) {
    display.setTextColor(YELLOW, BLACK);
    display.setTextSize(2);
    display.setCursor(45, 130);
    display.print("Keine Alarme gespeichert");
    drawBackButton();
    return;
  }

  int startY = 65;
  int rowH = 38;

  for (int i = 0; i < lineCount; i++) {
    unsigned long epoch;
    float temp, hum, pressure, gas;
    String status;

    if (!parseAlarmLine(lines[i], epoch, temp, hum, pressure, gas, status)) continue;
    DateTime dt(epoch);
    int y = startY + i * rowH;
    display.drawFastHLine(25, y - 5, 425, DARKGRAY);
    display.setTextSize(1);
    display.setTextColor(RED, BLACK);
    display.setCursor(25, y);
    if (dt.day() < 10) display.print("0");
    display.print(dt.day());
    display.print(".");
    if (dt.month() < 10) display.print("0");
    display.print(dt.month());
    display.print(" ");
    if (dt.hour() < 10) display.print("0");
    display.print(dt.hour());
    display.print(":");
    if (dt.minute() < 10) display.print("0");
    display.print(dt.minute());
    display.setTextColor(WHITE, BLACK);
    display.setCursor(115, y);
    display.print("Gas:"); display.print(gas, 1); display.print("K");
    display.setCursor(210, y);
    display.print("T:"); display.print(temp, 1); display.print("C");
    display.setCursor(290, y);
    display.print("F:"); display.print(hum, 1); display.print("%");
    display.setCursor(370, y);
    display.print(status);
  }
  drawBackButton();
}

// ======================================================
// GRAPH SCREEN
// ======================================================

void drawGraphModeButton(int x, const char* label, GraphMode mode) {
  uint16_t fillColor = DARKGRAY;
  if (currentGraphMode == mode) fillColor = getGraphColor(mode);
  display.fillRoundRect(x, GBTN_Y, GBTN_W, GBTN_H, 7, fillColor);
  display.drawRoundRect(x, GBTN_Y, GBTN_W, GBTN_H, 7, WHITE);
  if (currentGraphMode == mode) {
    display.setTextColor(BLACK, fillColor);
  } else {
    display.setTextColor(WHITE, fillColor);
  }
  display.setTextSize(1);
  display.setCursor(x + 15, GBTN_Y + 10);
  display.print(label);
}

void drawGraphButtons() {
  disableTouch();
  drawGraphModeButton(GBTN_TEMP_X, "TEMP", GRAPH_TEMP);
  drawGraphModeButton(GBTN_HUM_X, "FEUCHTE", GRAPH_HUM);
  drawGraphModeButton(GBTN_PRESS_X, "DRUCK", GRAPH_PRESSURE);
  drawGraphModeButton(GBTN_GAS_X, "GAS", GRAPH_GAS);
}

void drawGraphScreen() {
  disableTouch();
  display.fillScreen(BLACK);
  display.drawRect(10, 14, 460, 288, WHITE);
  display.fillRect(10, 14, 460, 42, NAVY);
  display.setTextColor(WHITE, NAVY);
  display.setTextSize(2);
  display.setCursor(25, 26);
  display.print("24h Verlauf: ");
  display.print(getGraphTitle(currentGraphMode));

  HourlyPoint points[24];
  calculateHourlyPoints(points);

  int gx = 58;
  int gy = 78;
  int gw = 355;
  int gh = 130;
  display.drawRect(gx, gy, gw, gh, WHITE);

  bool hasAny = false;
  float minValue = 100000;
  float maxValue = -100000;

  for (int i = 0; i < 24; i++) {
    if (points[i].hasData) {
      float value = getGraphValue(points[i], currentGraphMode);
      hasAny = true;
      if (value < minValue) minValue = value;
      if (value > maxValue) maxValue = value;
    }
  }

  if (!hasAny) {
    display.setTextColor(YELLOW, BLACK);
    display.setTextSize(2);
    display.setCursor(90, 135);
    display.print("Noch keine Logdaten");
    drawGraphButtons();
    drawBackButton();
    return;
  }

  if (maxValue - minValue < 1.0) {
    maxValue += 0.5;
    minValue -= 0.5;
  }

  uint16_t graphColor = getGraphColor(currentGraphMode);
  display.setTextColor(CYAN, BLACK);
  display.setTextSize(1);
  display.setCursor(12, gy);
  display.print(maxValue, 1);
  display.print(getGraphUnit(currentGraphMode));
  display.setCursor(12, gy + gh - 8);
  display.print(minValue, 1);
  display.print(getGraphUnit(currentGraphMode));

  for (int i = 1; i < 4; i++) {
    int yy = gy + (gh * i / 4);
    for (int x = gx + 1; x < gx + gw - 1; x += 12) {
      display.drawFastHLine(x, yy, 6, DARKGRAY);
    }
  }

  int lastX = -1;
  int lastY = -1;
  for (int i = 0; i < 24; i++) {
    int px = gx + map(i, 0, 23, 6, gw - 6);
    if (points[i].hasData) {
      float value = getGraphValue(points[i], currentGraphMode);
      int py = gy + gh - 1 - (int)((value - minValue) * (gh - 12) / (maxValue - minValue));
      py = constrain(py, gy + 6, gy + gh - 6);
      display.fillCircle(px, py, 3, graphColor);
      if (lastX >= 0) display.drawLine(lastX, lastY, px, py, YELLOW);
      lastX = px;
      lastY = py;
    }
  }

  display.setTextColor(WHITE, BLACK);
  display.setTextSize(2);
  display.setCursor(58, 212);
  display.print(getGraphTitle(currentGraphMode));
  display.print(" in ");
  display.print(getGraphUnit(currentGraphMode));
  drawGraphButtons();
  drawBackButton();
}

// ======================================================
// BUTTON + BUZZER
// ======================================================

void handleButton() {
  bool buttonPressed = (digitalRead(BUTTON_PIN) == LOW);
  if (buttonPressed && millis() - lastButtonPress > debounceDelay) {
    lastButtonPress = millis();
    if (airBad) {
      alarmMuted = !alarmMuted;
      if (alarmMuted) {
        Serial.println("Alarm quittiert.");
        digitalWrite(BUZZER_PIN, LOW);
        buzzerState = false;
      } else {
        Serial.println("Alarm wieder aktiviert.");
      }
      updateFooterStatus();
    } else {
      Serial.println("Button gedrueckt, aber kein Alarm aktiv.");
    }
  }
}

void handleBuzzer() {
  if (!airBad || alarmMuted) {
    digitalWrite(BUZZER_PIN, LOW);
    buzzerState = false;
    return;
  }

  if (millis() - lastBuzzerToggle >= buzzerInterval) {
    lastBuzzerToggle = millis();
    buzzerState = !buzzerState;
    digitalWrite(BUZZER_PIN, buzzerState ? HIGH : LOW);
  }
}

// ======================================================
// TOUCH HANDLING
// ======================================================

void handleTouch() {
  disableDisplay();
  if (!touch.touched()) return;
  if (millis() - lastTouchAction < touchDebounceDelay) return;

  TS_Point p = touch.getPoint();
  int screenX, screenY;
  mapTouchToScreen(p.x, p.y, screenX, screenY);

  Serial.print("Touch screen x=");
  Serial.print(screenX);
  Serial.print(" y=");
  Serial.print(screenY);
  Serial.print(" raw z=");
  Serial.println(p.z);

  if (currentScreen == SCREEN_MAIN) {
    if (isInside(screenX, screenY, STAT_BTN_X, STAT_BTN_Y, STAT_BTN_W, STAT_BTN_H)) {
      lastTouchAction = millis();
      currentScreen = SCREEN_STATS;
      statsNeedsRefresh = false;
      drawStatsScreen();
      return;
    }
  }

  if (currentScreen == SCREEN_STATS) {
    if (isInside(screenX, screenY, ALARM_BTN_X, ALARM_BTN_Y, ALARM_BTN_W, ALARM_BTN_H)) {
      lastTouchAction = millis();
      currentScreen = SCREEN_ALARMS;
      alarmLogNeedsRefresh = false;
      drawAlarmLogScreen();
      return;
    }

    if (isInside(screenX, screenY, GRAPH_BTN_X, GRAPH_BTN_Y, GRAPH_BTN_W, GRAPH_BTN_H)) {
      lastTouchAction = millis();
      currentScreen = SCREEN_GRAPH;
      graphNeedsRefresh = false;
      drawGraphScreen();
      return;
    }

    if (isInside(screenX, screenY, BACK_BTN_X, BACK_BTN_Y, BACK_BTN_W, BACK_BTN_H)) {
      lastTouchAction = millis();
      currentScreen = SCREEN_MAIN;
      drawStaticUI();
      updateClock();
      updateMainMeasurementDisplay();
      return;
    }
  }

  if (currentScreen == SCREEN_GRAPH) {
    if (isInside(screenX, screenY, GBTN_TEMP_X, GBTN_Y, GBTN_W, GBTN_H)) {
      lastTouchAction = millis();
      currentGraphMode = GRAPH_TEMP;
      graphNeedsRefresh = false;
      drawGraphScreen();
      return;
    }

    if (isInside(screenX, screenY, GBTN_HUM_X, GBTN_Y, GBTN_W, GBTN_H)) {
      lastTouchAction = millis();
      currentGraphMode = GRAPH_HUM;
      graphNeedsRefresh = false;
      drawGraphScreen();
      return;
    }

    if (isInside(screenX, screenY, GBTN_PRESS_X, GBTN_Y, GBTN_W, GBTN_H)) {
      lastTouchAction = millis();
      currentGraphMode = GRAPH_PRESSURE;
      graphNeedsRefresh = false;
      drawGraphScreen();
      return;
    }

    if (isInside(screenX, screenY, GBTN_GAS_X, GBTN_Y, GBTN_W, GBTN_H)) {
      lastTouchAction = millis();
      currentGraphMode = GRAPH_GAS;
      graphNeedsRefresh = false;
      drawGraphScreen();
      return;
    }

    if (isInside(screenX, screenY, BACK_BTN_X, BACK_BTN_Y, BACK_BTN_W, BACK_BTN_H)) {
      lastTouchAction = millis();
      currentScreen = SCREEN_STATS;
      statsNeedsRefresh = false;
      drawStatsScreen();
      return;
    }
  }

  if (currentScreen == SCREEN_ALARMS) {
    if (isInside(screenX, screenY, BACK_BTN_X, BACK_BTN_Y, BACK_BTN_W, BACK_BTN_H)) {
      lastTouchAction = millis();
      currentScreen = SCREEN_STATS;
      statsNeedsRefresh = false;
      drawStatsScreen();
      return;
    }
  }
}

// ======================================================
// SENSOR UPDATE
// ======================================================

void updateSensorData() {
  if (!bme.performReading()) {
    Serial.println("Messung fehlgeschlagen!");

    if (currentScreen == SCREEN_MAIN) {
      disableTouch();
      display.fillRect(220, FOOTER_Y, 135, FOOTER_H, NAVY);
      display.setTextColor(RED, NAVY);
      display.setTextSize(2);
      display.setCursor(225, 282);
      display.print("Messfehler");
    }
    return;
  }

  currentTemp = bme.temperature + TEMP_OFFSET;
  currentHum = bme.humidity;
  currentPressure = (bme.pressure / 100.0) + PRESSURE_OFFSET;
  currentGas = bme.gas_resistance / 1000.0;
  hasSensorReading = true;

  sumTemp += currentTemp;
  sumHum += currentHum;
  sumPressure += currentPressure;
  sumGas += currentGas;
  statsCount++;

  if (FORCE_ALARM_TEST) {
    airBad = true;
  } else {
    airBad = currentGas < GAS_BAD_THRESHOLD;
  }

  if (airBad && !lastAirBadState) {
    saveAlarmToLog("Schlecht");
  }

  lastAirBadState = airBad;

  if (!airBad) {
    alarmMuted = false;
  }

  Serial.println("------ Umweltwerte ------");
  Serial.print("Temperatur kalibriert: "); Serial.print(currentTemp); Serial.println(" C");
  Serial.print("Feuchtigkeit: "); Serial.print(currentHum); Serial.println(" %");
  Serial.print("Druck: "); Serial.print(currentPressure); Serial.println(" hPa");
  Serial.print("Gas: "); Serial.print(currentGas); Serial.println(" KOhm");
  Serial.print("Luftqualitaet: ");
  if (currentGas >= GAS_MEDIUM_THRESHOLD) Serial.println("Gut");
  else if (currentGas >= GAS_BAD_THRESHOLD) Serial.println("Mittel");
  else Serial.println("Schlecht");
  Serial.print("Alarm aktiv: "); Serial.println(airBad ? "JA" : "NEIN");
  Serial.print("Alarm quittiert: "); Serial.println(alarmMuted ? "JA" : "NEIN");
  Serial.println("-------------------------");

  if (currentScreen == SCREEN_MAIN) {
    updateMainMeasurementDisplay();
  }
}

// ======================================================
// LOGGING TIMER
// ======================================================

void handleLogging() {
  if (!hasSensorReading) return;

  if (millis() - lastLogSave >= logInterval) {
    lastLogSave = millis();
    saveMeasurementToLog();
    pruneOldLogEntries();
    pruneOldAlarmEntries();
    statsNeedsRefresh = true;
    graphNeedsRefresh = true;
  }
}

// ======================================================
// SETUP
// ======================================================

void setup() {
  Serial.begin(115200);
  delay(1500);
  Serial.println("Starte Umweltstation mit Alarm-Protokoll...");

  SPI.begin(18, 19, 23);
  pinMode(TFT_CS, OUTPUT);
  pinMode(TOUCH_CS, OUTPUT);
  digitalWrite(TFT_CS, HIGH);
  digitalWrite(TOUCH_CS, HIGH);

  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  Wire.begin(I2C_SDA, I2C_SCL);
  initStorage();

  disableTouch();
  display.init(320, 480, 0, 0, ST7796S_RGB);
  display.setRotation(DISPLAY_ROTATION);
  showStartupMessage("Starte...", WHITE);

  disableDisplay();
  touch.begin();
  touch.setRotation(TOUCH_ROTATION);

  if (!rtc.begin()) {
    showStartupMessage("RTC fehlt!", RED);
    Serial.println("RTC nicht gefunden!");
    while (1) delay(1000);
  }

  Serial.println("RTC gefunden!");

  if (rtc.lostPower()) {
    Serial.println("RTC Zeit verloren. Setze Kompilierzeit...");
    rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
  } else {
    Serial.println("RTC Zeit vorhanden. Kein Reset der Uhrzeit.");
  }

  Serial.println("Starte BME680...");

  if (!bme.begin(0x76)) {
    Serial.println("BME680 nicht bei 0x76 gefunden. Teste 0x77...");
    if (!bme.begin(0x77)) {
      showStartupMessage("BME680 fehlt!", RED);
      while (1) {
        Serial.println("BME680 fehlt weiterhin.");
        delay(1500);
      }
    }
  }

  Serial.println("BME680 erfolgreich initialisiert!");
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
  bme.setGasHeater(320, 150);

  currentScreen = SCREEN_MAIN;
  drawStaticUI();
  updateClock();
  updateFooterStatus();
  lastLogSave = millis();
  Serial.println("Setup fertig.");
}

// ======================================================
// LOOP
// ======================================================

void loop() {
  handleTouch();
  handleButton();
  handleBuzzer();

  if (millis() - lastClockUpdate >= clockUpdateInterval) {
    lastClockUpdate = millis();
    updateClock();
  }

  if (millis() - lastSensorUpdate >= sensorUpdateInterval) {
    lastSensorUpdate = millis();
    updateSensorData();
  }

  handleLogging();

  if (currentScreen == SCREEN_STATS && statsNeedsRefresh) {
    statsNeedsRefresh = false;
    drawStatsScreen();
  }

  if (currentScreen == SCREEN_GRAPH && graphNeedsRefresh) {
    graphNeedsRefresh = false;
    drawGraphScreen();
  }

  if (currentScreen == SCREEN_ALARMS && alarmLogNeedsRefresh) {
    alarmLogNeedsRefresh = false;
    drawAlarmLogScreen();
  }
}
