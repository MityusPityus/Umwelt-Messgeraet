// ======================================================
// HILFSFUNKTIONEN
// ======================================================

void disableDisplay() {
  digitalWrite(TFT_CS, HIGH);
  delayMicroseconds(5);
}

void disableTouch() {
  digitalWrite(TOUCH_CS, HIGH);
  delayMicroseconds(5);
}

float clampFloat(float value, float minVal, float maxVal) {
  if (value < minVal) return minVal;
  if (value > maxVal) return maxVal;
  return value;
}

int mapGasToPercent(float gasKOhm) {
  gasKOhm = clampFloat(gasKOhm, 50.0, 140.0);
  return (int)((gasKOhm - 50.0) * 100.0 / 90.0);
}

void mapTouchToScreen(int rawX, int rawY, int &screenX, int &screenY) {
  int x = rawX;
  int y = rawY;

  if (TOUCH_SWAP_XY) {
    int temp = x;
    x = y;
    y = temp;
  }

  screenX = map(x, TOUCH_MIN_X, TOUCH_MAX_X, 0, SCREEN_W - 1);
  screenY = map(y, TOUCH_MIN_Y, TOUCH_MAX_Y, 0, SCREEN_H - 1);

  if (TOUCH_INVERT_X) {
    screenX = (SCREEN_W - 1) - screenX;
  }

  if (TOUCH_INVERT_Y) {
    screenY = (SCREEN_H - 1) - screenY;
  }

  screenX = screenX + TOUCH_OFFSET_X;
  screenY = screenY + TOUCH_OFFSET_Y;

  screenX = constrain(screenX, 0, SCREEN_W - 1);
  screenY = constrain(screenY, 0, SCREEN_H - 1);
}

bool isInside(int x, int y, int bx, int by, int bw, int bh) {
  return (x >= bx && x <= bx + bw && y >= by && y <= by + bh);
}

void showStartupMessage(const char* msg, uint16_t color) {
  disableTouch();
  display.fillScreen(BLACK);
  display.setTextColor(color, BLACK);
  display.setTextSize(3);
  display.setCursor(35, 135);
  display.print(msg);
}

// ======================================================
// CSV HELPER
// ======================================================

String getCsvField(String line, int index) {
  int currentIndex = 0;
  int start = 0;

  for (int i = 0; i <= line.length(); i++) {
    if (i == line.length() || line.charAt(i) == ';') {
      if (currentIndex == index) {
        return line.substring(start, i);
      }
      currentIndex++;
      start = i + 1;
    }
  }
  return "";
}

bool parseLogLine(String line, unsigned long &epoch, float &temp, float &hum, float &pressure, float &gas) {
  line.trim();
  if (line.length() < 5) return false;
  if (line.startsWith("epoch")) return false;

  String f0 = getCsvField(line, 0);
  String f1 = getCsvField(line, 1);
  String f2 = getCsvField(line, 2);
  String f3 = getCsvField(line, 3);
  String f4 = getCsvField(line, 4);

  if (f0.length() == 0 || f1.length() == 0 || f2.length() == 0 || f3.length() == 0 || f4.length() == 0) return false;

  epoch = strtoul(f0.c_str(), NULL, 10);
  temp = f1.toFloat();
  hum = f2.toFloat();
  pressure = f3.toFloat();
  gas = f4.toFloat();
  return true;
}

bool parseAlarmLine(String line, unsigned long &epoch, float &temp, float &hum, float &pressure, float &gas, String &status) {
  line.trim();
  if (line.length() < 5) return false;
  if (line.startsWith("epoch")) return false;

  String f0 = getCsvField(line, 0);
  String f1 = getCsvField(line, 1);
  String f2 = getCsvField(line, 2);
  String f3 = getCsvField(line, 3);
  String f4 = getCsvField(line, 4);
  String f5 = getCsvField(line, 5);

  if (f0.length() == 0 || f1.length() == 0 || f2.length() == 0 || f3.length() == 0 || f4.length() == 0) return false;

  epoch = strtoul(f0.c_str(), NULL, 10);
  temp = f1.toFloat();
  hum = f2.toFloat();
  pressure = f3.toFloat();
  gas = f4.toFloat();
  status = f5;
  return true;
}

unsigned long getHourNumber(unsigned long epoch) {
  return epoch / 3600UL;
}

// ======================================================
// LITTLEFS
// ======================================================

void initStorage() {
  if (!LittleFS.begin(true)) {
    Serial.println("LittleFS konnte nicht gestartet werden.");
    return;
  }

  Serial.println("LittleFS gestartet.");

  if (!LittleFS.exists(LOG_FILE)) {
    File file = LittleFS.open(LOG_FILE, FILE_WRITE);
    if (file) {
      file.println("epoch;temp;hum;pressure;gas");
      file.close();
      Serial.println("Mess-Logdatei erstellt.");
    }
  }

  if (!LittleFS.exists(ALARM_FILE)) {
    File file = LittleFS.open(ALARM_FILE, FILE_WRITE);
    if (file) {
      file.println("epoch;temp;hum;pressure;gas;status");
      file.close();
      Serial.println("Alarm-Logdatei erstellt.");
    }
  }
}

void saveMeasurementToLog() {
  if (!hasSensorReading) return;

  DateTime now = rtc.now();
  unsigned long epoch = now.unixtime();

  File file = LittleFS.open(LOG_FILE, FILE_APPEND);
  if (!file) {
    Serial.println("Logdatei konnte nicht geoeffnet werden.");
    return;
  }

  file.print(epoch);
  file.print(";");
  file.print(currentTemp, 2);
  file.print(";");
  file.print(currentHum, 2);
  file.print(";");
  file.print(currentPressure, 2);
  file.print(";");
  file.println(currentGas, 2);
  file.close();
  Serial.println("Messwert gespeichert.");
}

void saveAlarmToLog(const char* statusText) {
  if (!hasSensorReading) return;

  DateTime now = rtc.now();
  unsigned long epoch = now.unixtime();

  File file = LittleFS.open(ALARM_FILE, FILE_APPEND);
  if (!file) {
    Serial.println("Alarmdatei konnte nicht geoeffnet werden.");
    return;
  }

  file.print(epoch);
  file.print(";");
  file.print(currentTemp, 2);
  file.print(";");
  file.print(currentHum, 2);
  file.print(";");
  file.print(currentPressure, 2);
  file.print(";");
  file.print(currentGas, 2);
  file.print(";");
  file.println(statusText);
  file.close();

  alarmLogNeedsRefresh = true;
  Serial.println("Alarmereignis gespeichert.");
}

void pruneOldLogEntries() {
  DateTime now = rtc.now();
  unsigned long nowEpoch = now.unixtime();

  if (!LittleFS.exists(LOG_FILE)) return;

  File input = LittleFS.open(LOG_FILE, FILE_READ);
  File output = LittleFS.open("/temp_log.csv", FILE_WRITE);

  if (!input || !output) {
    Serial.println("Prune Messlog fehlgeschlagen.");
    if (input) input.close();
    if (output) output.close();
    return;
  }

  output.println("epoch;temp;hum;pressure;gas");

  while (input.available()) {
    String line = input.readStringUntil('\n');
    line.trim();

    unsigned long epoch;
    float temp, hum, pressure, gas;

    if (parseLogLine(line, epoch, temp, hum, pressure, gas)) {
      if (epoch <= nowEpoch && nowEpoch - epoch <= STORAGE_RETENTION_SECONDS) {
        output.println(line);
      }
    }
  }

  input.close();
  output.close();
  LittleFS.remove(LOG_FILE);
  LittleFS.rename("/temp_log.csv", LOG_FILE);
  Serial.println("Alte Mess-Logeintraege entfernt.");
}

void pruneOldAlarmEntries() {
  DateTime now = rtc.now();
  unsigned long nowEpoch = now.unixtime();

  if (!LittleFS.exists(ALARM_FILE)) return;

  File input = LittleFS.open(ALARM_FILE, FILE_READ);
  File output = LittleFS.open("/temp_alarm.csv", FILE_WRITE);

  if (!input || !output) {
    Serial.println("Prune Alarmlog fehlgeschlagen.");
    if (input) input.close();
    if (output) output.close();
    return;
  }

  output.println("epoch;temp;hum;pressure;gas;status");

  while (input.available()) {
    String line = input.readStringUntil('\n');
    line.trim();

    unsigned long epoch;
    float temp, hum, pressure, gas;
    String status;

    if (parseAlarmLine(line, epoch, temp, hum, pressure, gas, status)) {
      if (epoch <= nowEpoch && nowEpoch - epoch <= STORAGE_RETENTION_SECONDS) {
        output.println(line);
      }
    }
  }

  input.close();
  output.close();
  LittleFS.remove(ALARM_FILE);
  LittleFS.rename("/temp_alarm.csv", ALARM_FILE);
  Serial.println("Alte Alarm-Logeintraege entfernt.");
}

// ======================================================
// STATISTIK AUS LOG
// ======================================================

AverageStats makeEmptyAverageStats() {
  AverageStats result;
  result.hasData = false;
  result.count = 0;
  result.avgTemp = 0;
  result.avgHum = 0;
  result.avgPressure = 0;
  result.avgGas = 0;
  return result;
}

AverageStats calculateAverageForRange(unsigned long fromEpoch, unsigned long toEpoch) {
  AverageStats result = makeEmptyAverageStats();
  float sTemp = 0;
  float sHum = 0;
  float sPressure = 0;
  float sGas = 0;

  File file = LittleFS.open(LOG_FILE, FILE_READ);
  if (!file) return result;

  while (file.available()) {
    String line = file.readStringUntil('\n');
    line.trim();

    unsigned long epoch;
    float temp, hum, pressure, gas;

    if (parseLogLine(line, epoch, temp, hum, pressure, gas)) {
      if (epoch >= fromEpoch && epoch <= toEpoch) {
        sTemp += temp;
        sHum += hum;
        sPressure += pressure;
        sGas += gas;
        result.count++;
      }
    }
  }

  file.close();

  if (result.count > 0) {
    result.hasData = true;
    result.avgTemp = sTemp / result.count;
    result.avgHum = sHum / result.count;
    result.avgPressure = sPressure / result.count;
    result.avgGas = sGas / result.count;
  }

  return result;
}

AverageStats calculateTodayAverage() {
  DateTime now = rtc.now();
  DateTime startOfDay(now.year(), now.month(), now.day(), 0, 0, 0);
  return calculateAverageForRange(startOfDay.unixtime(), now.unixtime());
}

AverageStats calculateLast24HoursAverage() {
  DateTime now = rtc.now();
  unsigned long nowEpoch = now.unixtime();
  unsigned long fromEpoch = nowEpoch - LAST_24H_SECONDS;
  return calculateAverageForRange(fromEpoch, nowEpoch);
}

void calculateHourlyPoints(HourlyPoint points[24]) {
  for (int i = 0; i < 24; i++) {
    points[i].hasData = false;
    points[i].hourNumber = 0;
    points[i].avgTemp = 0;
    points[i].avgHum = 0;
    points[i].avgPressure = 0;
    points[i].avgGas = 0;
  }

  DateTime now = rtc.now();
  unsigned long currentHour = getHourNumber(now.unixtime());

  float sumTemp[24];
  float sumHum[24];
  float sumPressure[24];
  float sumGas[24];
  unsigned long count[24];

  for (int i = 0; i < 24; i++) {
    sumTemp[i] = 0;
    sumHum[i] = 0;
    sumPressure[i] = 0;
    sumGas[i] = 0;
    count[i] = 0;
    unsigned long hourNum = currentHour - (23 - i);
    points[i].hourNumber = hourNum;
  }

  File file = LittleFS.open(LOG_FILE, FILE_READ);
  if (!file) return;

  while (file.available()) {
    String line = file.readStringUntil('\n');
    line.trim();

    unsigned long epoch;
    float temp, hum, pressure, gas;

    if (parseLogLine(line, epoch, temp, hum, pressure, gas)) {
      unsigned long hourNum = getHourNumber(epoch);
      for (int i = 0; i < 24; i++) {
        if (points[i].hourNumber == hourNum) {
          sumTemp[i] += temp;
          sumHum[i] += hum;
          sumPressure[i] += pressure;
          sumGas[i] += gas;
          count[i]++;
          break;
        }
      }
    }
  }

  file.close();

  for (int i = 0; i < 24; i++) {
    if (count[i] > 0) {
      points[i].hasData = true;
      points[i].avgTemp = sumTemp[i] / count[i];
      points[i].avgHum = sumHum[i] / count[i];
      points[i].avgPressure = sumPressure[i] / count[i];
      points[i].avgGas = sumGas[i] / count[i];
    }
  }
}

float getGraphValue(HourlyPoint p, GraphMode mode) {
  if (mode == GRAPH_TEMP) return p.avgTemp;
  if (mode == GRAPH_HUM) return p.avgHum;
  if (mode == GRAPH_PRESSURE) return p.avgPressure;
  if (mode == GRAPH_GAS) return p.avgGas;
  return 0;
}

const char* getGraphTitle(GraphMode mode) {
  if (mode == GRAPH_TEMP) return "Temperatur";
  if (mode == GRAPH_HUM) return "Feuchte";
  if (mode == GRAPH_PRESSURE) return "Druck";
  if (mode == GRAPH_GAS) return "Gas";
  return "";
}

const char* getGraphUnit(GraphMode mode) {
  if (mode == GRAPH_TEMP) return "C";
  if (mode == GRAPH_HUM) return "%";
  if (mode == GRAPH_PRESSURE) return "hPa";
  if (mode == GRAPH_GAS) return "KOhm";
  return "";
}

uint16_t getGraphColor(GraphMode mode) {
  if (mode == GRAPH_TEMP) return ORANGE;
  if (mode == GRAPH_HUM) return CYAN;
  if (mode == GRAPH_PRESSURE) return MAGENTA;
  if (mode == GRAPH_GAS) return GREEN;
  return WHITE;
}

